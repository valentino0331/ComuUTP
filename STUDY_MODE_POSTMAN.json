    {
      "name": "Materials",
      "item": [
        {
          "name": "Upload Material",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer YOUR_JWT_TOKEN"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "courseId",
                  "value": "COURSE_ID",
                  "type": "text"
                },
                {
                  "key": "file",
                  "type": "file",
                  "src": "/path/to/your/file.pdf"
                }
              ]
            },
            "url": {
              "raw": "http://localhost:3000/api/materials/upload",
              "protocol": "http",
