# ========================================
# UTP COMUNIDADES - CONFIGURACIÓN
# ========================================
# Este archivo contiene las variables de entorno necesarias
# Copia este archivo a .env y completa con tus valores
# NUNCA commits .env a git

# ========================================
# ENTORNO
# ========================================
NODE_ENV=development
# Valores válidos: development, staging, production
# Afecta logging, validaciones de CORS, y comportamiento de errores

# ========================================
# SERVIDOR
# ========================================
PORT=3000
# Puerto en el que escucha el servidor

HOST=0.0.0.0
# Host en el que escucha (0.0.0.0 para Docker)

# ========================================
# BASE DE DATOS - PostgreSQL
# ========================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
# IMPORTANTE: Cambiar a contraseña fuerte en producción (mínimo 32 caracteres)

DB_NAME=utp_comunidades
# Nombre de la base de datos

DB_POOL_MIN=2
# Mínimo de conexiones en el pool

DB_POOL_MAX=20
# Máximo de conexiones en el pool

DB_SSL=false
# Usar SSL/TLS para conexiones remotas
# En producción: true (especialmente si BD está en cloud)

# ========================================
# AUTENTICACIÓN Y SEGURIDAD
# ========================================
JWT_SECRET=your_super_secret_key_minimum_32_characters_long_here
# CRÍTICO: Cambiar a valor seguro y aleatorio en producción
# Mínimo 32 caracteres, incluir símbolos, números, mayúsculas y minúsculas
# Ejemplo: aB3@xYz9$mK2&pL8#wQ5!rT7^vN6%sH4

JWT_EXPIRATION=24h
# Tiempo de expiración del token
# Formatos: "2h", "24h", "7d", "30d" o segundos (86400)

JWT_REFRESH_SECRET=your_refresh_secret_key_here
# Token de refresco para renovar JWT sin ir a login
# Puede ser igual a JWT_SECRET o uno diferente

BCRYPT_ROUNDS=10
# Número de rondas para hasheado de contraseñas
# Mayor = más seguro pero más lento (10-12 recomendado)

# ========================================
# FRONTEND (CORS)
# ========================================
FRONTEND_URL=http://localhost:3000
# URL del frontend para permitir CORS
# En producción: https://example.com

MOBILE_APP_URL=http://localhost
# URL de la app móvil (si aplica)

# ========================================
# LOGGING
# ========================================
LOG_LEVEL=debug
# Niveles: debug, info, warn, error
# development: debug, production: warn o info

LOG_FILES=true
# Guardar logs en archivos (en carpeta /logs)

LOG_TO_DB=true
# Guardar logs importantes en base de datos

# ========================================
# EMAIL (Opcional - para notificaciones)
# ========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your_app_specific_password
SMTP_FROM=noreply@example.com
# Solo requerido si se implementa email

# ========================================
# NOTIFICACIONES PUSH (Opcional)
# ========================================
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_PRIVATE_KEY=your_private_key
FIREBASE_CLIENT_EMAIL=your_email@project.iam.gserviceaccount.com
# Solo requerido si se usa Firebase para push notifications

# ========================================
# ALMACENAMIENTO (Opcional)
# ========================================
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_REGION=us-east-1
AWS_S3_BUCKET=your_bucket_name
# Solo requerido si se usa AWS S3 para uploads

# ========================================
# RATE LIMITING
# ========================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000
# Ventana de tiempo en milisegundos (900000 = 15 minutos)

RATE_LIMIT_MAX_REQUESTS=100
# Máximo de requests en la ventana de tiempo

# ========================================
# FEATURES (Feature Flags)
# ========================================
FEATURE_EMAIL_VERIFICATION=false
# Requerir verificación de email en registro

FEATURE_TWO_FACTOR_AUTH=false
# Activar autenticación de dos factores

FEATURE_NOTIFICATIONS=true
# Activar sistema de notificaciones

FEATURE_SOCIAL_LOGIN=false
# Permitir login con Google, GitHub, etc.

# ========================================
# MONITORING Y DEBUGGING
# ========================================
DEBUG=true
# Mostrar información de debug en console

SENTRY_DSN=
# DSN de Sentry para error tracking (opcional)

SLACK_WEBHOOK_URL=
# Webhook de Slack para alertas (opcional)

# ========================================
# SESIÓN
# ========================================
SESSION_SECRET=your_session_secret_here
SESSION_TIMEOUT_MS=3600000
# Timeout de sesión en milisegundos (3600000 = 1 hora)

# ========================================
# ARCHIVOS
# ========================================
UPLOAD_MAX_SIZE=52428800
# Tamaño máximo de upload en bytes (52428800 = 50MB)

UPLOAD_DIR=./uploads
# Directorio para uploads

ALLOWED_UPLOAD_TYPES=jpg,jpeg,png,gif,pdf,doc,docx
# Tipos de archivo permitidos

# ========================================
# CONFIGURACIÓN ADICIONAL
# ========================================
APP_VERSION=1.0.0
APP_NAME=UTP Comunidades
APP_DESCRIPTION=Plataforma de comunidades universitarias

TIMEZONE=America/Lima
# Zona horaria para la aplicación

# ========================================
# NOTAS IMPORTANTES
# ========================================
# 1. NUNCA incluir valores reales en git
# 2. Usar .env.local o .env.production para valores secretos
# 3. Validar todas las variables al iniciar la app
# 4. En producción:
#    - Usar HTTPS (JWT_SECRET más fuerte)
#    - DB_SSL=true
#    - NODE_ENV=production
#    - LOG_LEVEL=warn o info
#    - Usar variables de entorno del sistema, no archivo
# 5. Cambiar todos los values por defecto antes de ir a producción

# ========================================
# MODO ESTUDIO + IA (NUEVO FEATURE)
# ========================================

# ========== OpenAI Integration ==========
OPENAI_API_KEY=sk-your-openai-api-key-here
# Obtener en: https://platform.openai.com/api-keys
# CRÍTICO: Guardar en secreto, monitorear uso de API

OPENAI_MODEL=gpt-3.5-turbo
# Modelo a usar: gpt-3.5-turbo (recomendado), gpt-4, gpt-4-turbo
# Precios: 3.5-turbo es más barato

OPENAI_MAX_TOKENS=800
# Máximo de tokens por respuesta
# Summarize: 500, Explain: 600, Answer: 800

OPENAI_TEMPERATURE=0.7
# Creatividad de respuestas (0.0 = determinista, 1.0 = creativo)

OPENAI_REQUEST_TIMEOUT=30000
# Timeout para requests a OpenAI en milisegundos

# ========== Cloudinary Integration (File Storage) ==========
CLOUDINARY_NAME=your_cloudinary_name
# Nombre de tu cuenta en Cloudinary

CLOUDINARY_API_KEY=your_cloudinary_api_key
# Obtener en: https://cloudinary.com/console

CLOUDINARY_API_SECRET=your_cloudinary_api_secret
# CRÍTICO: Guardar en secreto

CLOUDINARY_FOLDER=utp/study
# Carpeta base para almacenar materiales de estudio

CLOUDINARY_RESOURCE_TYPE=auto
# Tipo de recurso: auto, image, video, raw

# ========== Study Mode Features ==========
STUDY_MODE_ENABLED=true
# Activar/desactivar el feature de Modo Estudio

AI_CACHE_ENABLED=true
# Cachear respuestas de IA para reutilizar

CACHE_TTL_HOURS=24
# Tiempo de vida del cache en horas

STUDY_DAILY_HABIT_ENABLED=true
# Activar notificaciones de hábito diario

STUDY_MAX_FILE_SIZE_MB=50
# Tamaño máximo de archivo a subir

STUDY_QUIZ_MAX_QUESTIONS=20
# Máximo de preguntas a generar en quiz

# ========== Study Mode Gamification ==========
STREAK_REWARD_POINTS=10
# Puntos al mantener racha diaria

BADGE_UNLOCK_REQUIREMENTS=5
# Número de acciones para desbloquear badge

MAX_STUDY_HOURS_PER_DAY=8
# Límite sugerido de horas de estudio por día

# ========== Study Analytics ==========
ENABLE_STUDY_ANALYTICS=true
# Registrar analytics de uso de Modo Estudio

ANALYTICS_RETENTION_DAYS=90
# Cuántos días mantener datos de analytics

# ========== Rate Limiting for AI Endpoints ==========
AI_RATE_LIMIT_WINDOW_MS=3600000
# Ventana de rate limit (1 hora)

AI_RATE_LIMIT_MAX_REQUESTS=50
# Máximo de llamadas a IA por usuario por ventana

# ========== Seguridad Modo Estudio ==========
VALIDATE_COURSE_OWNERSHIP=true
# Verificar que usuario es propietario del curso

VALIDATE_FILE_CONTENT=true
# Escanear contenido de archivo (malware, etc.)

REQUIRE_TERMS_ACCEPTED=true
# Requerir aceptar términos antes de usar IA
